{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "jsxImportSource": "reclassify",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "declaration": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "noEmit": true,
    "paths": {
      "reclassify": ["./src/index.ts"],
      "reclassify/jsx-runtime": ["./src/jsx-runtime.ts"],
      "reclassify/jsx-dev-runtime": ["./src/jsx-dev-runtime.ts"]
    },
    "skipLibCheck": true
  },
  "include": ["src", "tests/**/*.ts", "tests/**/*.tsx", "tests/**/*.d.ts", "vite.config.ts"]
}
